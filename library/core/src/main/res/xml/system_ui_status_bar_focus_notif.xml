<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:myLocation="@string/system_ui_statusbar_focus_notif_title"
    app:quick_restart="com.android.systemui">

    <PreferenceCategory android:title="@string/system_ui_statusbar_island_title">
        <Preference
            android:fragment="com.sevtinge.hyperceiler.hooker.systemui.statusbar.IslandMediaCardSettings"
            android:key="prefs_key_system_ui_status_bar_island_media_card"
            android:title="@string/system_ui_statusbar_island_media_card_title" />

        <Preference
            android:fragment="com.sevtinge.hyperceiler.hooker.systemui.statusbar.FocusNotificationLyricsSettings"
            android:title="@string/system_ui_statusbar_music_title" />

    </PreferenceCategory>


    <PreferenceCategory android:title="@string/system_ui_statusbar_strong_toast_title">
        <SwitchPreference
            android:defaultValue="false"
            android:key="prefs_key_system_ui_status_bar_hide_smart_strong_toast"
            android:title="@string/system_ui_status_bar_strong_toast_hide" />

        <Preference
            android:key="prefs_key_system_ui_status_bar_strong_toast_test_short_text"
            android:title="@string/system_ui_status_bar_strong_toast_test_short_text" />

        <Preference
            android:key="prefs_key_system_ui_status_bar_strong_toast_test_long_text"
            android:title="@string/system_ui_status_bar_strong_toast_test_long_text" />

    </PreferenceCategory>

</PreferenceScreen>