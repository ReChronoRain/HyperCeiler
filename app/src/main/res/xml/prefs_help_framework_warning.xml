<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

    <com.sevtinge.hyperceiler.prefs.LayoutPreference
        android:enabled="false"
        android:key="prefs_key_layout_framework_compatible"
        android:layout="@layout/headtip_tip"
        android:title="@string/help_framework_warning_card_compatible" />

    <com.sevtinge.hyperceiler.prefs.LayoutPreference
        android:enabled="false"
        android:key="prefs_key_layout_framework_service_error"
        android:layout="@layout/headtip_notice"
        android:title="@string/help_framework_warning_card_service_error" />

    <com.sevtinge.hyperceiler.prefs.LayoutPreference
        android:enabled="false"
        android:key="prefs_key_layout_framework_pending"
        android:layout="@layout/headtip_notice"
        android:title="@string/help_framework_warning_card_pending" />

    <com.sevtinge.hyperceiler.prefs.LayoutPreference
        android:enabled="false"
        android:key="prefs_key_layout_framework_incompatible"
        android:layout="@layout/headtip_warn"
        android:title="@string/help_framework_warning_card_incompatible" />

    <Preference
        android:enabled="false"
        android:key="prefs_key_textview_help_framework_warning"
        android:layout="@layout/preference_help"
        android:summary=""
        android:title="@string/help_framework_warning_title" />

</PreferenceScreen>
