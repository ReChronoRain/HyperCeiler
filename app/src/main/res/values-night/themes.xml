<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="LogViewerTheme" parent="Theme.AppCompat.DayNight">
        <item name="android:windowBackground">@color/miuix_design_default_color_surface_variant_dark</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
        <item name="android:useLocalePreferredLineHeightForMinimum">false</item>
        <item name="searchActionModeInputBackground">@android:color/transparent</item>

        <item name="preferenceCategoryTextColor">@color/miuix_preference_category_text_color_dark</item>

        <item name="itemViewTitleTextColor">@color/item_view_title_color_dark</item>
        <item name="itemViewSummaryTextColor">@color/item_view_summary_color_dark</item>
        <item name="itemViewArrowRightFillColor">@color/item_view_arrow_right_fill_color_dark</item>
        <item name="itemViewBackgroundColor">@color/item_view_bg_normal_color_dark</item>

        <item name="textColorDialogSingleChoiceItem">@color/miuix_appcompat_dialog_list_text_single_choice_dark</item>

        <item name="recyclerViewCardStyle">@style/LogViewerRecyclerViewCardStyle</item>

        <item name="endActionMenuEnabled">true</item>
        <item name="bottomSheetStyle">@style/BottomSheetModalStyle</item>
    </style>
</resources>
