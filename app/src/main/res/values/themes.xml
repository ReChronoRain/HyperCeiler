<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Base.Theme.HyperCeiler.DayNight" />

    <style name="SplashTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>

        <item name="alertDialogTheme">@layout/miuix_appcompat_alert_dialog_content</item>
    </style>

    <style name="LogViewerTheme" parent="Theme.AppCompat.DayNight">
        <item name="android:windowBackground">@color/miuix_design_default_color_surface_variant_light</item>
        <item name="searchActionModeInputBackground">@android:color/transparent</item>

        <item name="preferenceCategoryTextColor">@color/miuix_preference_category_text_color_light</item>

        <item name="itemViewTitleTextColor">@color/item_view_title_color_light</item>
        <item name="itemViewSummaryTextColor">@color/item_view_summary_color_light</item>
        <item name="itemViewArrowRightFillColor">@color/item_view_arrow_right_fill_color_light</item>
        <item name="itemViewBackgroundColor">@color/item_view_bg_normal_color_light</item>

        <item name="textColorDialogSingleChoiceItem">@color/miuix_appcompat_dialog_list_text_single_choice_light</item>

        <item name="recyclerViewCardStyle">@style/LogViewerRecyclerViewCardStyle</item>

        <item name="endActionMenuEnabled">true</item>
    </style>
</resources>